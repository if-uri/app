# Example env for the ifuri-runtime systemd user unit.
# Copy: mkdir -p ~/.config/ifuri && cp systemd/ifuri-runtime.env.example ~/.config/ifuri/runtime.env
#
# Values here override the unit defaults. Use absolute paths (env files do not
# expand %h / ~).

IFURI_HOME=/home/youruser/.ifuri
# Pin a compiled urirun registry the node serves:
# IFURI_URIRUN_REGISTRY=/home/youruser/.ifuri/registry.json
